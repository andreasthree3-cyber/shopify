{%- comment -%}Usage: {% render 'product-card', product: product, variant: variant %}{%- endcomment -%}
<article class="product-card">
  <a href="{{ product.url }}" class="product-card__media">
    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 600 | image_tag: alt: product.title, class: 'product-card__image', loading: 'lazy' }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
    {%- endif -%}
  </a>
  <div class="product-card__body">
    <a href="{{ product.url }}" class="product-card__title-link">
      <h3 class="product-card__title">{{ product.title }}</h3>
    </a>
    {%- if variant -%}
      <div class="product-card__variant">{{ variant.title }}</div>
      <div class="product-card__price">
        <strong>{{ variant.price | money }}</strong>
        <small>inkl. MwSt. · <a href="/pages/versandbedingungen">zzgl. Versand</a></small>
        <small>Lieferzeit 1–3 Arbeitstage</small>
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="btn btn--brand btn--block" {% unless variant.available %}disabled{% endunless %}>
          {% if variant.available %}In den Warenkorb{% else %}Ausverkauft{% endif %}
        </button>
      </form>
    {%- endif -%}
  </div>
</article>
