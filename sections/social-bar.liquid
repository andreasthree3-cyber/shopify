<section class="social-bar">
  <div class="container">
    <p class="social-bar__label">{{ section.settings.label }}</p>
    <div class="social-bar__items">
      {%- for block in section.blocks -%}
        <span class="social-bar__tag" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Bar",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Wirkt bei den häufigsten Flecken" }
  ],
  "blocks": [
    { "type": "item", "name": "Eintrag", "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Kaffee" }] }
  ],
  "default": {
    "blocks": [
      { "type": "item", "settings": { "text": "Restaurant" } },
      { "type": "item", "settings": { "text": "Reise" } },
      { "type": "item", "settings": { "text": "Hochzeit" } },
      { "type": "item", "settings": { "text": "Büro" } },
      { "type": "item", "settings": { "text": "Auto" } },
      { "type": "item", "settings": { "text": "Urlaub" } }
    ]
  },
  "presets": [{ "name": "Social Bar" }]
}
{% endschema %}
