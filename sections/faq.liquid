<section class="faq container" id="faq">
  <h2 class="faq__title">{{ section.settings.title }}</h2>
  <div class="faq__list">
    {%- for block in section.blocks -%}
      <details class="faq__item" {{ block.shopify_attributes }}>
        <summary>{{ block.settings.q }}<span aria-hidden="true">+</span></summary>
        <div class="faq__answer">{{ block.settings.a }}</div>
      </details>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "title", "label": "Titel", "default": "Häufige Fragen" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Frage",
      "settings": [
        { "type": "text", "id": "q", "label": "Frage" },
        { "type": "richtext", "id": "a", "label": "Antwort" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "qa", "settings": { "q": "Auf welchen Stoffen kann ich den FleckenXperte verwenden?", "a": "<p>Für die meisten waschbaren Stoffe geeignet. Nicht für Leder, Wildleder, Seide oder empfindliche Materialien. Vorher an verdeckter Stelle testen.</p>" } },
      { "type": "qa", "settings": { "q": "Wie ergiebig ist ein Stift?", "a": "<p>5 g Inhalt – reicht für viele kleine Erstbehandlungen unterwegs.</p>" } },
      { "type": "qa", "settings": { "q": "Wie hoch sind die Versandkosten?", "a": "<p>Innerhalb Deutschlands 3,99 €. Ab 50 € Bestellwert versandkostenfrei.</p>" } }
    ]
  },
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
