<footer class="site-footer">
  <div class="container site-footer__inner">
    <!-- Brand / Tagline Column -->
    <div class="site-footer__col site-footer__brand-col">
      <p class="site-footer__name">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px; vertical-align:middle; color:#3b82f6;">
          <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/>
          <line x1="12" y1="22" x2="12" y2="15.5"/>
          <polyline points="22 8.5 12 15.5 2 8.5"/>
          <polyline points="2 15.5 12 8.5 22 15.5"/>
        </svg>
        <span>FleckenXperte</span>
      </p>
      <p class="site-footer__tagline">{{ section.settings.tagline | default: 'Der Fleckenentferner-Stift für unterwegs. Hilft schnell und schonend bei Kaffee, Wein, Soße & Co.' }}</p>
    </div>

    <!-- Shop Links Column -->
    <div class="site-footer__col">
      <h4 class="site-footer__heading">Shop</h4>
      <ul class="site-footer__links">
        <li><a href="#produkt">Produkt</a></li>
        <li><a href="#vorteile">Vorteile</a></li>
        <li><a href="#anwendung">Anwendung</a></li>
      </ul>
    </div>

    <!-- Legal Links Column -->
    <div class="site-footer__col">
      <h4 class="site-footer__heading">Service/Rechtliches</h4>
      <ul class="site-footer__links">
        <li><a href="/pages/impressum">Impressum</a></li>
        <li><a href="/pages/datenschutz">Datenschutz</a></li>
        <li><a href="/pages/agb">AGB</a></li>
        <li><a href="/pages/widerrufsrecht">Widerrufsrecht</a></li>
        <li><a href="/pages/versandbedingungen">Versandbedingungen</a></li>
        <li><a href="/pages/produktsicherheit">Produktsicherheit (GPSR)</a></li>
      </ul>
    </div>
  </div>

  <!-- Center Action Button -->
  <div class="site-footer__action-row container">
    <a href="/pages/widerruf-formular" class="btn btn--footer-form">
      EU-Widerrufsformular ausfüllen
    </a>
  </div>

  <!-- Bottom Details -->
  <div class="site-footer__bottom container">
    <p>© {{ 'now' | date: '%Y' }} FleckenXperte. Alle Rechte vorbehalten.</p>
    <p>Sichere Bezahlung über Shopify · Bezahlt mit Lastschrift, Kreditkarte, PayPal &amp; mehr</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Der Fleckenentferner-Stift für unterwegs. Hilft schnell und schonend bei Kaffee, Wein, Soße & Co." }
  ]
}
{% endschema %}
