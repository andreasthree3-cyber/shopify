<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">{{ shop.name }}</p>
      <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
    </div>

    {%- for block in section.blocks -%}
      <div class="site-footer__col" {{ block.shopify_attributes }}>
        <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
        <ul class="site-footer__links">
          {%- for link in block.settings.menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endfor -%}
  </div>

  <div class="site-footer__bottom container">
    <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Alle Rechte vorbehalten.</p>
    <p>Sichere Bezahlung über Shopify &amp; PayPal · Versand 3,99 € · ab 50 € versandkostenfrei (DE)</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Erste Hilfe bei Flecken — der Stift, der immer dabei ist." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menü-Spalte",
      "settings": [
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Service" },
        { "type": "link_list", "id": "menu", "label": "Menü", "default": "footer" }
      ]
    }
  ],
  "default": {
    "blocks": [{ "type": "menu" }]
  }
}
{% endschema %}
