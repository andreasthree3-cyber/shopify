<section class="featured-product container" id="produkt">
  <header class="featured-product__head-section">
    <span class="eyebrow">{{ section.settings.eyebrow | default: 'Shop' }}</span>
    <h2>{{ section.settings.title | default: 'Hol dir deinen FleckenXperte' }}</h2>
    <p class="featured-product__subtitle">
      Erhältlich als Einzelstift, 6er-Pack und 12er-Pack.<br>
      Versand 3,99 € · ab 50 € versandkostenfrei (DE)
    </p>
  </header>

  <!-- Popular callout box -->
  <div class="featured-product__popular-box">
    <div class="featured-product__popular-badge">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#22d3ee" stroke="#22d3ee" stroke-width="1">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      <strong>Beliebt: das 6er-Pack</strong>
    </div>
    <p>Je einer für Handtasche, Auto, Büro, Reisegepäck, Zuhause & als Reserve — so bist du überall vorbereitet.</p>
  </div>

  {%- assign fallback_handle = section.settings.product_handle | default: 'fleckenxperte-to-go-stift' -%}
  {%- assign product = all_products[fallback_handle] -%}
  
  {%- assign has_product = false -%}
  {%- if product != blank and product.handle != blank -%}
    {%- assign has_product = true -%}
  {%- endif -%}

  <div class="featured-product__card-wrapper">
    <article class="featured-product__main-card">
      <div class="featured-product__card-media">
        {%- if has_product and product.featured_image != blank -%}
          {{ product.featured_image | image_url: width: 800 | image_tag: alt: product.title, loading: 'lazy' }}
        {%- else -%}
          <img src="{{ 'hero-stick.png' | asset_url }}" alt="FleckenXperte TO GO" loading="lazy" width="400" height="400">
        {%- endif -%}
      </div>
      
      <div class="featured-product__card-body">
        <h3 class="featured-product__card-title">
          {%- if has_product -%}
            {{ product.title }}
          {%- else -%}
            FleckenXperte TO GO – Fleckenentferner-Stift (5 g)
          {%- endif -%}
        </h3>
        <p class="featured-product__card-sub">Erhältlich als 1 Stück, 6er- und 12er-Pack</p>
        
        <div class="featured-product__card-footer">
          <div class="featured-product__card-price">
            <span class="price-ab">AB</span>
            <span class="price-amount">
              {%- if has_product -%}
                {{ product.price_min | money }}
              {%- else -%}
                2,99 €
              {%- endif -%}
            </span>
            <span class="price-vat">inkl. MwSt.</span>
            <span class="price-unit">59,80 € / 100 g</span>
          </div>
          
          <a href="{% if has_product %}{{ product.url }}{% else %}/products/fleckenxperte-to-go-stift{% endif %}" class="btn btn--brand btn-choose">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <span>Wählen</span>
          </a>
        </div>
      </div>
    </article>
  </div>

  <!-- Trust badges below the card -->
  <div class="featured-product__trust-badges">
    <div class="trust-badge">
      <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="3" width="15" height="13" rx="2" ry="2"/>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <span>Versand aus Deutschland</span>
    </div>
    
    <div class="trust-badge">
      <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
        <line x1="1" y1="10" x2="23" y2="10"/>
      </svg>
      <span>PayPal & Kreditkarte</span>
    </div>
    
    <div class="trust-badge">
      <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
        <polyline points="16 3 21 8 21 3"/>
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
        <polyline points="8 21 3 16 3 21"/>
      </svg>
      <span>14 Tage Widerrufsrecht</span>
    </div>
    
    <div class="trust-badge">
      <svg class="trust-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <path d="m9 11 2 2 4-4"/>
      </svg>
      <span>GPSR-konform</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Hol dir deinen FleckenXperte" },
    { "type": "text", "id": "product_handle", "label": "Produkt-Handle", "default": "fleckenxperte-to-go-stift" }
  ],
  "presets": [{ "name": "Featured Product" }]
}
{% endschema %}
